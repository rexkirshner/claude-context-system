{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/rexkirshner/claude-context-system/schemas/sessions-data.json",
  "title": "Claude Context System - Sessions Data",
  "description": "Machine-readable session history for multi-agent workflows",
  "type": "object",
  "properties": {
    "metadata": {
      "type": "object",
      "description": "Metadata about this export",
      "properties": {
        "version": {
          "type": "string",
          "description": "Claude Context System version",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "exportedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When this JSON was generated"
        },
        "projectName": {
          "type": "string",
          "description": "Project name from config"
        },
        "totalSessions": {
          "type": "integer",
          "description": "Total number of sessions",
          "minimum": 0
        }
      },
      "required": ["version", "exportedAt", "totalSessions"]
    },
    "sessions": {
      "type": "array",
      "description": "Array of session objects",
      "items": {
        "type": "object",
        "properties": {
          "sessionNumber": {
            "type": "integer",
            "description": "Session number (sequential)",
            "minimum": 1
          },
          "date": {
            "type": "string",
            "format": "date",
            "description": "Session date (YYYY-MM-DD)"
          },
          "phase": {
            "type": "string",
            "description": "Development phase at time of session"
          },
          "duration": {
            "type": "string",
            "description": "Session duration (e.g., '2h')"
          },
          "focus": {
            "type": "string",
            "description": "Brief description of session focus"
          },
          "status": {
            "type": "string",
            "enum": ["✅", "⏳", "❌", "complete", "in_progress", "blocked"],
            "description": "Session completion status"
          },
          "changed": {
            "type": "array",
            "description": "Key accomplishments",
            "items": {
              "type": "string"
            }
          },
          "problemSolved": {
            "type": "object",
            "description": "Problem-solving approach for AI agents",
            "properties": {
              "issue": {
                "type": "string",
                "description": "What problem was addressed"
              },
              "constraints": {
                "type": "string",
                "description": "What limitations existed"
              },
              "approach": {
                "type": "string",
                "description": "How the problem was solved"
              },
              "rationale": {
                "type": "string",
                "description": "Why this approach was chosen"
              }
            }
          },
          "decisions": {
            "type": "array",
            "description": "Decisions made this session",
            "items": {
              "type": "object",
              "properties": {
                "topic": {
                  "type": "string",
                  "description": "Decision topic"
                },
                "summary": {
                  "type": "string",
                  "description": "Brief decision summary"
                },
                "decisionId": {
                  "type": "string",
                  "description": "Reference to DECISIONS.md entry (e.g., 'D001')"
                }
              }
            }
          },
          "files": {
            "type": "object",
            "description": "Files changed this session",
            "properties": {
              "new": {
                "type": "array",
                "description": "New files created",
                "items": {
                  "type": "object",
                  "properties": {
                    "path": {
                      "type": "string",
                      "description": "File path"
                    },
                    "description": {
                      "type": "string",
                      "description": "Purpose and key contents"
                    },
                    "lines": {
                      "type": "string",
                      "description": "Line range (e.g., '1-150')"
                    }
                  }
                }
              },
              "modified": {
                "type": "array",
                "description": "Modified files",
                "items": {
                  "type": "object",
                  "properties": {
                    "path": {
                      "type": "string",
                      "description": "File path"
                    },
                    "description": {
                      "type": "string",
                      "description": "What changed and why"
                    },
                    "lines": {
                      "type": "string",
                      "description": "Line range (e.g., '123-145')"
                    }
                  }
                }
              },
              "deleted": {
                "type": "array",
                "description": "Deleted files",
                "items": {
                  "type": "object",
                  "properties": {
                    "path": {
                      "type": "string",
                      "description": "File path"
                    },
                    "reason": {
                      "type": "string",
                      "description": "Why removed"
                    }
                  }
                }
              }
            }
          },
          "mentalModels": {
            "type": "object",
            "description": "Developer's mental models (critical for AI agents)",
            "properties": {
              "currentUnderstanding": {
                "type": "string",
                "description": "Mental model of the system"
              },
              "keyInsights": {
                "type": "array",
                "description": "Insights AI agents should know",
                "items": {
                  "type": "string"
                }
              },
              "gotchas": {
                "type": "array",
                "description": "Non-obvious things discovered",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "workInProgress": {
            "type": "object",
            "description": "Incomplete work details",
            "properties": {
              "task": {
                "type": "string",
                "description": "What's incomplete"
              },
              "location": {
                "type": "string",
                "description": "File path and line/function"
              },
              "currentApproach": {
                "type": "string",
                "description": "Mental model of approach"
              },
              "rationale": {
                "type": "string",
                "description": "Why this approach"
              },
              "nextAction": {
                "type": "string",
                "description": "Exact next step"
              },
              "contextNeeded": {
                "type": "string",
                "description": "What to remember to resume"
              }
            }
          },
          "todoWriteState": {
            "type": "object",
            "description": "TodoWrite snapshot from this session",
            "properties": {
              "completed": {
                "type": "array",
                "description": "Completed todos",
                "items": {
                  "type": "string"
                }
              },
              "incomplete": {
                "type": "array",
                "description": "Incomplete todos",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "nextSession": {
            "type": "object",
            "description": "Planning for next session",
            "properties": {
              "priority": {
                "type": "string",
                "description": "Most important next action"
              },
              "blockers": {
                "type": "array",
                "description": "Blockers with details",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "required": ["sessionNumber", "date"]
      }
    }
  },
  "required": ["metadata", "sessions"]
}
