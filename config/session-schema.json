{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Session Log",
  "description": "Machine-readable session activity log",
  "type": "object",
  "required": ["sessionNumber", "startTime", "focus"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Schema version",
      "default": "1.0.0"
    },
    "sessionNumber": {
      "type": "integer",
      "minimum": 1,
      "description": "Session number"
    },
    "startTime": {
      "type": "string",
      "format": "date-time",
      "description": "Session start timestamp (ISO 8601)"
    },
    "endTime": {
      "type": "string",
      "format": "date-time",
      "description": "Session end timestamp (ISO 8601)"
    },
    "duration": {
      "type": "object",
      "properties": {
        "hours": {
          "type": "number",
          "minimum": 0,
          "description": "Duration in hours"
        },
        "minutes": {
          "type": "integer",
          "minimum": 0,
          "description": "Duration in minutes"
        },
        "humanReadable": {
          "type": "string",
          "description": "Human-readable duration (e.g., '2.5 hours')"
        }
      }
    },
    "focus": {
      "type": "string",
      "description": "Main work area or focus for this session"
    },
    "accomplishments": {
      "type": "array",
      "description": "List of accomplishments during this session",
      "items": {
        "type": "object",
        "required": ["description"],
        "properties": {
          "description": {
            "type": "string",
            "description": "What was accomplished"
          },
          "files": {
            "type": "array",
            "description": "Files involved in this accomplishment",
            "items": {
              "type": "string"
            }
          },
          "lineReferences": {
            "type": "array",
            "description": "Specific line references",
            "items": {
              "type": "object",
              "required": ["file", "lines"],
              "properties": {
                "file": {
                  "type": "string",
                  "description": "File path"
                },
                "lines": {
                  "type": "string",
                  "description": "Line numbers (e.g., '123-145' or '67')"
                },
                "change": {
                  "type": "string",
                  "description": "What changed"
                }
              }
            }
          }
        }
      }
    },
    "filesModified": {
      "type": "array",
      "description": "Files modified during this session",
      "items": {
        "type": "object",
        "required": ["path", "change"],
        "properties": {
          "path": {
            "type": "string",
            "description": "File path"
          },
          "change": {
            "type": "string",
            "description": "Description of changes"
          },
          "lineNumbers": {
            "type": "string",
            "description": "Specific line numbers modified"
          },
          "linesAdded": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of lines added"
          },
          "linesRemoved": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of lines removed"
          }
        }
      }
    },
    "filesCreated": {
      "type": "array",
      "description": "New files created during this session",
      "items": {
        "type": "object",
        "required": ["path", "purpose"],
        "properties": {
          "path": {
            "type": "string",
            "description": "File path"
          },
          "purpose": {
            "type": "string",
            "description": "Purpose of this file"
          },
          "lines": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of lines in file"
          }
        }
      }
    },
    "filesDeleted": {
      "type": "array",
      "description": "Files deleted during this session",
      "items": {
        "type": "object",
        "required": ["path", "reason"],
        "properties": {
          "path": {
            "type": "string",
            "description": "File path"
          },
          "reason": {
            "type": "string",
            "description": "Why file was deleted"
          }
        }
      }
    },
    "decisionsMade": {
      "type": "array",
      "description": "Technical decisions made during this session",
      "items": {
        "type": "object",
        "required": ["decision"],
        "properties": {
          "decision": {
            "type": "string",
            "description": "What was decided"
          },
          "rationale": {
            "type": "string",
            "description": "Why this decision was made"
          },
          "alternatives": {
            "type": "array",
            "description": "Alternatives considered",
            "items": {
              "type": "string"
            }
          },
          "documentedIn": {
            "type": "string",
            "description": "Reference to DECISIONS.md entry"
          }
        }
      }
    },
    "issuesDiscovered": {
      "type": "array",
      "description": "Issues discovered during this session",
      "items": {
        "type": "object",
        "required": ["title", "severity"],
        "properties": {
          "title": {
            "type": "string",
            "description": "Issue title"
          },
          "severity": {
            "type": "string",
            "enum": ["blocking", "non-critical", "minor"],
            "description": "Issue severity"
          },
          "description": {
            "type": "string",
            "description": "Issue description"
          },
          "workaround": {
            "type": "string",
            "description": "Temporary workaround if any"
          },
          "documentedIn": {
            "type": "string",
            "description": "Reference to KNOWN_ISSUES.md entry"
          }
        }
      }
    },
    "issuesResolved": {
      "type": "array",
      "description": "Issues resolved during this session",
      "items": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": {
            "type": "string",
            "description": "Issue title"
          },
          "solution": {
            "type": "string",
            "description": "How it was resolved"
          },
          "files": {
            "type": "array",
            "description": "Files involved in the fix",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "commandsRun": {
      "type": "array",
      "description": "Key commands executed during this session",
      "items": {
        "type": "object",
        "required": ["command"],
        "properties": {
          "command": {
            "type": "string",
            "description": "The command that was run"
          },
          "purpose": {
            "type": "string",
            "description": "Why this command was run"
          },
          "result": {
            "type": "string",
            "description": "Result or outcome"
          }
        }
      }
    },
    "gitActivity": {
      "type": "object",
      "properties": {
        "commits": {
          "type": "array",
          "description": "Commits made during this session",
          "items": {
            "type": "object",
            "required": ["hash", "message"],
            "properties": {
              "hash": {
                "type": "string",
                "description": "Commit hash (short or full)"
              },
              "message": {
                "type": "string",
                "description": "Commit message"
              },
              "filesChanged": {
                "type": "integer",
                "description": "Number of files changed"
              }
            }
          }
        },
        "branch": {
          "type": "string",
          "description": "Branch worked on"
        },
        "pushed": {
          "type": "boolean",
          "description": "Whether changes were pushed"
        }
      }
    },
    "workInProgress": {
      "type": "object",
      "description": "Work in progress at end of session",
      "properties": {
        "active": {
          "type": "boolean",
          "description": "Is there unfinished work?"
        },
        "task": {
          "type": "string",
          "description": "Exact task in progress"
        },
        "files": {
          "type": "array",
          "description": "Files being worked on",
          "items": {
            "type": "object",
            "required": ["path"],
            "properties": {
              "path": {
                "type": "string",
                "description": "File path"
              },
              "lineNumber": {
                "type": "integer",
                "description": "Current line number"
              },
              "description": {
                "type": "string",
                "description": "What's being done"
              }
            }
          }
        },
        "approach": {
          "type": "string",
          "description": "Mental model or approach being used"
        },
        "nextAction": {
          "type": "string",
          "description": "Next specific action to take"
        }
      }
    },
    "nextSteps": {
      "type": "array",
      "description": "Next steps for following session",
      "items": {
        "type": "object",
        "required": ["action"],
        "properties": {
          "action": {
            "type": "string",
            "description": "Action to take"
          },
          "priority": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"],
            "description": "Action priority"
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "description": "Additional notes or context",
      "items": {
        "type": "string"
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "generatedBy": {
          "type": "string",
          "description": "Tool/command that generated this file",
          "default": "/save-context"
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When this file was generated"
        }
      }
    }
  }
}
