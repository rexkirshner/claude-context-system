{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Project State",
  "description": "Current state of the project for fast agent loading",
  "type": "object",
  "required": ["version", "lastUpdated", "sessionNumber"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Schema version"
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last update"
    },
    "sessionNumber": {
      "type": "integer",
      "minimum": 1,
      "description": "Current session number"
    },
    "project": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Project name"
        },
        "phase": {
          "type": "string",
          "description": "Current development phase"
        },
        "status": {
          "type": "string",
          "description": "One-sentence project status"
        }
      }
    },
    "currentFocus": {
      "type": "object",
      "properties": {
        "task": {
          "type": "string",
          "description": "Current task or work area"
        },
        "description": {
          "type": "string",
          "description": "Detailed description of current work"
        },
        "approach": {
          "type": "string",
          "description": "Mental model or approach being used"
        },
        "nextAction": {
          "type": "string",
          "description": "Exact next action to take"
        }
      }
    },
    "workInProgress": {
      "type": "object",
      "properties": {
        "active": {
          "type": "boolean",
          "description": "Is there work in progress?"
        },
        "files": {
          "type": "array",
          "description": "Files currently being edited",
          "items": {
            "type": "object",
            "required": ["path"],
            "properties": {
              "path": {
                "type": "string",
                "description": "File path"
              },
              "lineNumber": {
                "type": "integer",
                "description": "Current line number of work"
              },
              "description": {
                "type": "string",
                "description": "What's being done to this file"
              }
            }
          }
        },
        "context": {
          "type": "string",
          "description": "Additional WIP context"
        }
      }
    },
    "blockers": {
      "type": "array",
      "description": "Current blockers preventing progress",
      "items": {
        "type": "object",
        "required": ["id", "description", "severity"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique blocker ID"
          },
          "description": {
            "type": "string",
            "description": "What's blocking progress"
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"],
            "description": "Blocker severity"
          },
          "workaround": {
            "type": "string",
            "description": "Temporary workaround if any"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "When blocker was identified"
          }
        }
      }
    },
    "recentAccomplishments": {
      "type": "array",
      "description": "Last 5-10 major accomplishments",
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": ["description", "sessionNumber"],
        "properties": {
          "description": {
            "type": "string",
            "description": "What was accomplished"
          },
          "sessionNumber": {
            "type": "integer",
            "description": "Session where this was accomplished"
          },
          "files": {
            "type": "array",
            "description": "Key files modified",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "nextSteps": {
      "type": "array",
      "description": "Immediate next actions",
      "items": {
        "type": "object",
        "required": ["action", "priority"],
        "properties": {
          "action": {
            "type": "string",
            "description": "Action to take"
          },
          "priority": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"],
            "description": "Action priority"
          },
          "context": {
            "type": "string",
            "description": "Additional context for the action"
          }
        }
      }
    },
    "keyFiles": {
      "type": "array",
      "description": "Most important files in the project",
      "items": {
        "type": "object",
        "required": ["path", "purpose"],
        "properties": {
          "path": {
            "type": "string",
            "description": "File path"
          },
          "purpose": {
            "type": "string",
            "description": "What this file does"
          },
          "lastModified": {
            "type": "string",
            "format": "date-time",
            "description": "Last modification timestamp"
          }
        }
      }
    },
    "recentDecisions": {
      "type": "array",
      "description": "Last 3-5 important decisions",
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["decision", "date"],
        "properties": {
          "decision": {
            "type": "string",
            "description": "What was decided"
          },
          "date": {
            "type": "string",
            "format": "date",
            "description": "Date of decision"
          },
          "rationale": {
            "type": "string",
            "description": "Why this decision was made"
          }
        }
      }
    },
    "knownIssues": {
      "type": "object",
      "properties": {
        "blocking": {
          "type": "integer",
          "description": "Number of blocking issues"
        },
        "nonCritical": {
          "type": "integer",
          "description": "Number of non-critical issues"
        },
        "minor": {
          "type": "integer",
          "description": "Number of minor issues"
        },
        "topIssues": {
          "type": "array",
          "description": "Top 3 issues by priority",
          "maxItems": 3,
          "items": {
            "type": "object",
            "required": ["title", "severity"],
            "properties": {
              "title": {
                "type": "string",
                "description": "Issue title"
              },
              "severity": {
                "type": "string",
                "enum": ["blocking", "non-critical", "minor"],
                "description": "Issue severity"
              }
            }
          }
        }
      }
    },
    "technicalDebt": {
      "type": "array",
      "description": "Known technical debt items",
      "items": {
        "type": "object",
        "required": ["description", "impact"],
        "properties": {
          "description": {
            "type": "string",
            "description": "Debt description"
          },
          "impact": {
            "type": "string",
            "enum": ["high", "medium", "low"],
            "description": "Impact of this debt"
          },
          "location": {
            "type": "string",
            "description": "Where in codebase"
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When state tracking started"
        },
        "totalSessions": {
          "type": "integer",
          "description": "Total sessions so far"
        },
        "projectAge": {
          "type": "string",
          "description": "Human-readable project age"
        }
      }
    }
  }
}
